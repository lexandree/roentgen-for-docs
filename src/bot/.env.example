# ==========================================
# TELEGRAM BOT SETTINGS (Cloud/Server)
# ==========================================

# Your Telegram Bot Token from BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The URL of your Local Server's API (the Dispatcher)
# If both are running on the same machine, use 127.0.0.1
LOCAL_API_URL=http://127.0.0.1:8000/api/v1

# Request Timeout (how long the bot waits for the Dispatcher to finish in seconds)
# Should match or exceed the REQUEST_TIMEOUT of the dispatcher.
REQUEST_TIMEOUT=300.0

# --- Google Drive & Whitelist Integration ---
# Absolute path to your service account JSON file
GOOGLE_DRIVE_CREDENTIALS_FILE_PATH=gdrive_credentials.json

# The ID of the Google Doc/Sheet containing the users whitelist
WHITELIST_FILE_ID=your_gdrive_file_id_here
