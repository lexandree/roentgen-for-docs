# ==========================================
# DISPATCHER API SETTINGS (Cloud/Server)
# ==========================================

# Database for local storage (sessions, logs)
# Use absolute paths if deploying via systemd: sqlite+aiosqlite:////absolute/path/local_data.db
DB_PATH=sqlite+aiosqlite:///local_data.db

# Request Timeout (how long the dispatcher waits for the worker to finish in seconds)
REQUEST_TIMEOUT=300.0

# Session Expiration (how long to keep context history in seconds)
SESSION_TIMEOUT_SECONDS=3600

# --- Google Drive & Whitelist Integration ---
# Absolute path to your service account JSON file
GOOGLE_DRIVE_CREDENTIALS_FILE_PATH=gdrive_credentials.json

# The ID of the Google Doc/Sheet containing the users whitelist
WHITELIST_FILE_ID=your_gdrive_file_id_here

# The ID of the Google Drive folder used for cloud batch workers (Colab/Kaggle)
GDRIVE_BATCH_FOLDER_ID=optional_folder_id_here

# --- Worker Routing ---
# JSON Dictionary defining available inference workers.
# Example: {"local_python":{"name":"Мой ПК","url":"http://127.0.0.1:8080"}}
# If using a Native C++ Worker (llama-server), append /v1/chat/completions to the URL.
INFERENCE_WORKERS={"local_python":{"name":"⚡️ Мой ПК","url":"http://127.0.0.1:8080"}}
