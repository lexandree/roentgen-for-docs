# API Settings (Local Server)
DB_PATH=sqlite+aiosqlite:///local_data.db

# Google Drive Whitelist Settings
# JSON string of your service account credentials
GOOGLE_DRIVE_CREDENTIALS_JSON={"type": "service_account", ...}
WHITELIST_FILE_ID=your_gdrive_file_id_here

# Llama.cpp Inference Settings (Optional, defaults shown below)
# LLAMA_MODEL_FILENAME=medgemma-1.5-4b.gguf
# LLAMA_CLIP_FILENAME=mmproj-model-f16.gguf
# Set to -1 to use all GPU layers. Reduce (e.g. 24) to save VRAM on smaller GPUs (like 6GB GTX 1060).
# LLAMA_N_GPU_LAYERS=-1
# Context window size. 1024 saves VRAM and is usually enough for a single image + diagnosis.
# LLAMA_N_CTX=2048
# Number of CPU threads (optional)
# LLAMA_N_THREADS=4
