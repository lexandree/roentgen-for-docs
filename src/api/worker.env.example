# ==========================================
# INFERENCE WORKER SETTINGS (Local PC with GPU)
# ==========================================

# NOTE: The worker DOES NOT need database, telegram, or google drive credentials.
# It only needs paths to the model weights and performance tuning parameters.

# Files must be placed in the `models/` directory in the project root.
LLAMA_MODEL_FILENAME=medgemma-1.5-4b.gguf
LLAMA_CLIP_FILENAME=mmproj-model-f16.gguf

# Number of layers to offload to the GPU. 
# -1 means "offload everything". Decrease this (e.g., 20 or 24) if you encounter CUDA Out Of Memory.
LLAMA_N_GPU_LAYERS=-1 

# Maximum context size in tokens (images take up a lot of context).
# 2048 is recommended. Reduce to 1024 or 512 for GPUs with very low VRAM (like 3GB-4GB).
LLAMA_N_CTX=2048

# Maximum tokens to generate for the response text.
LLAMA_MAX_TOKENS=1024

# Number of CPU threads to use (leave blank to let llama.cpp decide based on your hardware)
# LLAMA_N_THREADS=8
